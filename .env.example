NUXT_PUBLIC_SUPABASE_URL=https://VOTRE_PROJECT_ID.supabase.co
NUXT_PUBLIC_SUPABASE_KEY=votre_cle_anon
SUPABASE_SERVICE_ROLE_KEY=votre_cle_service_role

# LLM — Ollama local (dev) : laisser les valeurs ci-dessous
# LLM — Groq (prod, gratuit) : changer BASE_URL et API_KEY
NUXT_OPENAI_BASE_URL=http://localhost:11434/v1
NUXT_OPENAI_API_KEY=ollama
NUXT_AI_MODEL=llama3.2:3b

# Pour Groq (gratuit, https://console.groq.com) :
# NUXT_OPENAI_BASE_URL=https://api.groq.com/openai/v1
